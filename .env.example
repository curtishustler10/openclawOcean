# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=8638578625:AAGDlsocxSplP0nvIBmz5t2ia9Cq1QE0C_8
TELEGRAM_CHAT_ID=    # Your personal chat ID (get it from @userinfobot)

# ── Agent Config ──────────────────────────────────────────────────────────────
PORT=3000
MAX_ITERATIONS=50

# ── Model Routing ─────────────────────────────────────────────────────────────
# Complex reasoning / analysis → this model (Anthropic)
COMPLEX_MODEL=claude-sonnet-4-6

# Coding tasks → Claude Code CLI by default
# Set to 'sonnet' to use the API instead of CLI
CODING_TIER=claude-code

# Admin / conversational → cheap/fast model
# Option A: Claude Haiku (Anthropic, cheap)
CHEAP_MODEL=claude-haiku-4-5-20251001
# Option B: Use a different provider (e.g. Google Gemini via LiteLLM, or OpenRouter)
# CHEAP_BASE_URL=http://localhost:4000/v1     # LiteLLM proxy
# CHEAP_BASE_URL=https://openrouter.ai/api/v1 # OpenRouter
# CHEAP_API_KEY=your-other-provider-key
# CHEAP_MODEL=gemini/gemini-2.0-flash         # Model name on that provider

# ── Telegram Webhook ──────────────────────────────────────────────────────────
# Your droplet's public IP (or domain if you have one)
PUBLIC_IP=170.64.166.135
WEBHOOK_PORT=8443

# ── Workspace ─────────────────────────────────────────────────────────────────
# Auto-detected — set only if deploying outside the repo root
# WORKSPACE_DIR=/home/axis/openclawOcean
